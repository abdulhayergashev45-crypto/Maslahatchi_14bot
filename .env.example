# .env fayli — bu faylni hech kimga ko'rsatmang!

# Telegram Bot Token (@BotFather dan oling)
BOT_TOKEN=your_telegram_bot_token_here

# Anthropic Claude API Key (console.anthropic.com dan oling)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Admin Telegram ID lari (vergul bilan ajrating)
# ID ni @userinfobot dan bilib olishingiz mumkin
ADMIN_IDS=123456789,987654321

# Google Sheets ID (ixtiyoriy — sheets URL dagi uzun kod)
# Masalan: https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
GOOGLE_SHEET_ID=
